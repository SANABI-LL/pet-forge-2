# pet-forge APNG route - API config
# ────────────────────────────────────
# Copy this file to .env and fill in your own API key.
# .env is ignored by git and must not be committed.
#
# Never hard-code API keys in source files.

# ── Doubao / Volcengine API ──────────────────────────────
# Register: https://www.volcengine.com/product/ark
# Fill in values according to the service dashboard.
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ── Model IDs ────────────────────────────────────────────
# Adjust these to models available in your service account.
DOUBAO_IMAGE_MODEL=doubao-seedream-5-0-260128
DOUBAO_VIDEO_MODEL=doubao-seedance-1-5-pro-251215
